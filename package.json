{
  "name": "shopify-clever",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm --prefix apps/shopify-app ci",
    "build": "npm --prefix apps/shopify-app run build",
    "typecheck": "npm --prefix apps/shopify-app run typecheck",
    "test:shopify-app": "cd apps/shopify-app && node --test tests/*.test.mjs",
    "test": "npm run test:shopify-app",
    "deploy:shopify-main": "docker compose -f infra/compose/docker-compose.shopify-main.yml up -d --build",
    "deploy:shopify-dev": "docker compose -f infra/compose/docker-compose.shopify-dev.yml up -d --build",
    "check:public-urls": "node scripts/check-public-url-hosts.mjs"
  }
}
