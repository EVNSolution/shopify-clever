NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL / Prisma
DATABASE_URL=postgresql://clever:clever@localhost:5432/clever_delivery
POSTGRES_DB=clever_delivery
POSTGRES_USER=clever
POSTGRES_PASSWORD=clever
POSTGRES_PORT=5432
API_PORT=3000

# Shopify app credentials and API version
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_WEBHOOK_SECRET=

# Optional single-shop local development shortcut only.
# Production should store each shop's Admin API token encrypted in the `shops` table.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# 32-byte key material for encrypting shop token ciphertext before database storage.
# Generate with: openssl rand -base64 32
SHOPIFY_TOKEN_ENCRYPTION_KEY=base64:replace-with-32-byte-base64-key

# Driver API auth secret; enables bearer-token route access follow-ups, consent records, and event ingest.
JWT_SECRET=change-me

# Driver proof media storage backend. Defaults to local when unset.
# Use local for development only; use s3 for production object storage and signed/read access.
DRIVER_PROOF_MEDIA_STORAGE_BACKEND=local

# Driver proof media local/dev storage root. Defaults to var/driver-proof-media when unset.
# The local filesystem backend does not expose file URLs.
DRIVER_PROOF_MEDIA_STORAGE_DIR=var/driver-proof-media

# Driver proof media S3-compatible object storage. Required when DRIVER_PROOF_MEDIA_STORAGE_BACKEND=s3.
# Keep access keys in the runtime secret store; do not commit real values.
DRIVER_PROOF_MEDIA_S3_BUCKET=
DRIVER_PROOF_MEDIA_S3_REGION=
DRIVER_PROOF_MEDIA_S3_ACCESS_KEY_ID=
DRIVER_PROOF_MEDIA_S3_SECRET_ACCESS_KEY=

# Optional S3-compatible endpoint and path-style controls for non-AWS providers/minio-style smoke.
# Leave endpoint unset for AWS S3 regional endpoints. Set force path style to true when the provider requires /bucket/key URLs.
DRIVER_PROOF_MEDIA_S3_ENDPOINT=
DRIVER_PROOF_MEDIA_S3_FORCE_PATH_STYLE=false
DRIVER_PROOF_MEDIA_S3_SESSION_TOKEN=

# Driver proof media signed/read access lifetime. Defaults to 300 seconds when unset.
DRIVER_PROOF_MEDIA_READ_ACCESS_TTL_SECONDS=300

# Driver proof media metadata/file retention window for cleanup jobs. Defaults to 180 days when unset.
DRIVER_PROOF_MEDIA_RETENTION_DAYS=180

# Optional HTTP scanner backend for sanitized proof-media bytes. Defaults to none when unset.
# Scanner endpoint receives sanitized file bytes plus metadata headers and returns {"status":"clean"}
# or {"status":"rejected","reason":"private reason"}.
DRIVER_PROOF_MEDIA_SCANNER_BACKEND=none
DRIVER_PROOF_MEDIA_SCANNER_URL=
DRIVER_PROOF_MEDIA_SCANNER_BEARER_TOKEN=

# Optional HTTP scan monitor backend for sanitized clean/rejected scan outcomes. Defaults to none.
# Monitor payload intentionally excludes proof file bytes.
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BACKEND=none
DRIVER_PROOF_MEDIA_SCAN_MONITOR_URL=
DRIVER_PROOF_MEDIA_SCAN_MONITOR_BEARER_TOKEN=

# Optional private evidence reference written to RetentionJobRun rows by the cleanup command.
# Use a private log/job URL or evidence-store key only; do not paste proof images, storage keys, or PII.
DRIVER_PROOF_MEDIA_CLEANUP_EVIDENCE_REF=
