# Normalize text files across macOS/Linux/Windows contributors.
* text=auto eol=lf

# Source-controlled text formats.
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.prisma text eol=lf
Dockerfile text eol=lf
Caddyfile.example text eol=lf
.env.example text eol=lf

# Evidence, backups, media, archives, and key/certificate artifacts should not
# be committed, but keep them binary if an explicit owner-approved exception is
# ever introduced.
*.png binary
*.jpg binary
*.jpeg binary
*.heic binary
*.heif binary
*.gif binary
*.webp binary
*.mp4 binary
*.mov binary
*.m4v binary
*.webm binary
*.pdf binary
*.zip binary
*.tar binary
*.tgz binary
*.gz binary
*.dump binary
*.sqlite binary
*.sqlite3 binary
*.db binary
*.pem binary
*.key binary
*.crt binary
*.p12 binary
*.p8 binary
